        "--ring-break": "#5a8ca0",
        "--shadow": "0 2px 12px rgba(80,50,20,0.10)",
        "--shadow-2": "0 4px 24px rgba(80,50,20,0.14)"
      },
      "fonts": {
        "--font-serif": ["Lora", "Georgia", "serif"],
        "--font-sans": ["Nunito", "system-ui", "sans-serif"],
        "--font-display": ["Lora", "Georgia", "serif"],
        "--font-mono": ["DM Mono", "ui-monospace", "Menlo", "monospace"]
      },
      "radii": {
        "--radius-sm": "8px",
        "--radius-md": "12px",
        "--radius-lg": "16px",
        "--radius-pill": "100px"
      },
      "easing": {
        "--ease-spring": "cubic-bezier(0.34, 1.56, 0.64, 1)",
        "--ease-out": "cubic-bezier(0.16, 1, 0.3, 1)"
      }
    }
  },

  "components": {
    "description": "Token-driven components. All read from CSS custom properties set by the active trend-variant class.",
    "react": {
      "Button": {
        "description": "Action control. Reads --accent, --surface, --border, --text. Pill radius per system rule.",
        "variants": {
          "primary": { "background": "var(--accent)", "color": "var(--bg, var(--paper, #fff))" },
          "secondary": { "background": "var(--surface)", "color": "var(--text, var(--ink))", "border": "1px solid var(--border)" },
          "ghost": { "background": "transparent", "color": "var(--accent)" }
        },
        "sizes": { "sm": "8px 16px", "md": "12px 24px", "lg": "15px 32px" },
        "props": ["variant", "size", "disabled", "iconBefore", "iconAfter", "onClick"],
        "radius": "var(--radius-full, 999px)",
        "promptFile": "components/core/Button.prompt.md"
      },
      "Card": {
        "description": "Surface container. Reads --surface, --border, --shadow, --radius. Interactive variant lifts on hover.",
        "props": ["interactive", "padding (default 20)", "as (element tag)"],
        "tokens": {
          "background": "var(--surface, #fff)",
          "border": "1px solid var(--border, rgba(127,127,127,0.16))",
          "radius": "var(--radius-md, 12px)",
          "shadow": "var(--shadow, 0 2px 12px rgba(80,50,20,0.10))",
          "hoverShadow": "var(--shadow-2, 0 4px 24px rgba(80,50,20,0.14))"
        },
        "promptFile": "components/core/Card.prompt.md"
      },
      "Badge": {
        "description": "Monospace pill for status, priority, metrics. 100px radius. Soft (tinted bg) or solid (filled) tones.",
        "tones": ["accent", "high", "medium", "low", "info", "muted"],
        "props": ["tone", "solid (boolean)"],
        "radius": "var(--radius-pill, 100px)",
        "promptFile": "components/core/Badge.prompt.md"
      }
    },
    "css": {
      ".btn": {
        "description": "Token-driven action button. Pill radius, reads --accent, --surface, --bg.",
        "radius": "var(--radius-full, 999px)",
        "hoverTransform": "scale(1.02)",
        "transition": "transform var(--ease-out) 0.2s, opacity 0.2s"
      },
      ".card": {
        "description": "Token-driven surface container. Reads --surface, --border, --text/--ink.",
        "radius": "var(--radius-md, 16px)",
        "hoverTransform": "translateY(-4px)",
        "padding": "var(--space-5, 24px)"
      }
    }
  },

  "guidelines": {
    "summary": "Full taste profile, pre-build gate, and anti-slop test in GUIDELINES.md",
    "colorRules": [
      "2-3 hues max. Richness from texture and depth, not hue count.",
      "All color in OKLCH tokens under tokens/trends/*.css — never raw hex in components.",
      "One trend-variant class per page. Components read --bg / --surface / --accent / --text / --muted / --border.",
      "Avoid purple-on-white SaaS gradient (instant disqualification)."
    ],
    "glassRules": [
      "Heavy frosted blur on every panel is OUT. Glass on floating/overlay elements only.",
      "Blur signals z-hierarchy — deeper blur = higher layer. Vary blur per layer.",
      "Every glass surface clears contrast ≥ 4.5:1 on its text.",
      "Default .glass; reserve .glass-deep for the single topmost element; .glass-dense when text needs opaque backing."
    ],
    "qualityGates": [
      "No placeholder copy ever. No 'Lorem ipsum', no 'Product Name'. Delivery-ready with real content.",
      "Pre-build gate: Purpose → Tone → Differentiation Anchor → Taste Alignment → Physical Scene Sentence → AI Slop Test."
    ]
  }
}
