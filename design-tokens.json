{
  "version": "1.0.0",
  "updated": "2026-06-21",
  "meta": {
    "name": "Jayden Design System",
    "description": "Trend-driven design system: 9 trends × 3 color variants (28 token sets) in OKLCH, plus a restraint-first glass component layer and token-driven React primitives.",
    "usage": "Pick one trend-variant class and apply it on <html> or a wrapper. Every component reads semantic tokens (--bg, --surface, --accent, --text, --muted) so the whole page re-themes from that one class.",
    "example": "<html class=\"liquid-glass-a\">",
    "links": {
      "readme": "README.md",
      "guidelines": "GUIDELINES.md",
      "skill": "SKILL.md",
      "entrypoint": "styles.css",
      "repo": "https://github.com/jayden2610/jayden-design-system"
    },
    "tokenFormat": "CSS custom properties. Apply the class on <html> — all children inherit.",
    "aiHint": "Pick ONE trend variant, read its tokens below, apply its CSS class. Never mix tokens from different trends."
  },

  "shared": {
    "description": "Base tokens shared across ALL trends. These are defined in tokens/base.css and never change between themes.",
    "spacing": {
      "scale": "8-point grid",
      "tokens": {
        "--space-1": "4px",
        "--space-2": "8px",
        "--space-3": "12px",
        "--space-4": "16px",
        "--space-5": "24px",
        "--space-6": "32px",
        "--space-7": "48px",
        "--space-8": "64px"
      }
    },
    "radii": {
      "rule": "16-20px ceiling on cards. Full-pill (999px) only for tags and buttons. --radius-card-max: 20px is the hard cap for non-pill elements.",
      "tokens": {
        "--radius-sm": "8px",
        "--radius-md": "16px",
        "--radius-card-max": "20px",
        "--radius-full": "999px"
      }
    },
    "easing": {
      "primary": "GSAP power3.out — dominant entrance easing across Trends 1, 2, 7",
      "tokens": {
        "--ease-out-power3": "cubic-bezier(0.16, 1, 0.3, 1)",
        "--ease-out": "cubic-bezier(0.16, 1, 0.3, 1)"
      }
    },
    "typography": {
      "description": "Defined in tokens/typography.css. Each trend may override --type-display clamp. Type pairings are prose-specified per trend.",
      "fonts": {
        "--font-display": ["General Sans", "Neue Montreal", "Söhne", "system-ui", "sans-serif"],
        "--font-sans": ["General Sans", "system-ui", "-apple-system", "sans-serif"],
        "--font-serif": ["Newsreader", "Georgia", "Times New Roman", "serif"],
        "--font-mono": ["JetBrains Mono", "ui-monospace", "SF Mono", "Menlo", "monospace"]
      },
      "scale": {
        "--type-display": "clamp(3rem, 8vw, 7rem)",
        "--type-h1": "clamp(2.25rem, 5vw, 4rem)",
        "--type-h2": "clamp(1.75rem, 3.4vw, 2.75rem)",
        "--type-h3": "clamp(1.35rem, 2.2vw, 1.75rem)",
        "--type-lead": "clamp(1.125rem, 1.6vw, 1.375rem)",
        "--type-body": "1rem",
        "--type-small": "0.875rem",
        "--type-eyebrow": "0.75rem"
      },
      "weights": {
        "--weight-regular": 400,
        "--weight-medium": 500,
        "--weight-semibold": 600,
        "--weight-bold": 700
      },
      "leading": {
        "--leading-tight": 1.05,
        "--leading-snug": 1.2,
        "--leading-normal": 1.6
      },
      "tracking": {
        "--tracking-tight": "-0.02em",
        "--tracking-normal": "0",
        "--tracking-eyebrow": "0.22em"
      }
    },
    "glass": {
      "description": "2026 Restraint Rule: heavy frosted blur on EVERY panel is OUT. Glass on floating/overlay elements only (nav, modals, popovers, one hero panel). Content surfaces sit on solid/near-solid backgrounds. Blur signals z-hierarchy.",
      "classes": {
        ".glass": {
          "usage": "Default — most floating elements",
          "background": "rgba(255,255,255,0.14)",
          "backdropFilter": "blur(20px) saturate(180%)",
          "border": "1px solid rgba(255,255,255,0.16)",
          "borderRadius": "20px",
          "boxShadow": ["0 8px 32px rgba(0,0,0,0.16)", "inset 0 1px 0 rgba(255,255,255,0.28)"]
        },
        ".glass-deep": {
          "usage": "Single topmost floating element only",
          "background": "rgba(255,255,255,0.18)",
          "backdropFilter": "blur(52px) saturate(220%)",
          "borderRadius": "20px",
          "boxShadow": ["0 8px 32px rgba(0,0,0,0.18)", "inset 0 1px 0 rgba(255,255,255,0.35)"]
        },
        ".glass-dense": {
          "usage": "When text needs reliable opaque backing (contrast ≥ 4.5:1)",
          "background": "rgba(255,255,255,0.42)",
          "backdropFilter": "blur(32px) saturate(180%)"
        },
        ".ambient-panel": {
          "usage": "Open World Ambient trend — floating UI panel over cinematic scene",
          "background": "rgba(255,255,255,0.18)",
          "backdropFilter": "blur(52px) saturate(220%)",
          "border": "1px solid rgba(255,255,255,0.18)",
          "borderRadius": "20px",
          "boxShadow": ["0 8px 32px rgba(0,0,0,0.18)", "inset 0 1px 0 rgba(255,255,255,0.35)"]
        }
      }
    }
  },

